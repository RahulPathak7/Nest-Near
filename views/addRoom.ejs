<!DOCTYPE html>
<html>
<head>
  <title>Add Room</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Leaflet CSS -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css"
  />

  <style>
    #map {
      height: 300px;
      border-radius: 10px;
    }
  </style>
</head>
<body class="bg-gray-100">

  <%- include("partials/navbar") %>

  <div class="max-w-2xl mx-auto mt-8 bg-white p-6 rounded shadow">
    <h2 class="text-2xl font-bold mb-4">Add Room</h2>

    <form action="/rooms/add" method="POST" enctype="multipart/form-data">

      <input type="text" name="title" placeholder="Title"
        class="w-full mb-3 p-2 border rounded" required>

      <input type="text" name="address" placeholder="Address"
        class="w-full mb-3 p-2 border rounded" required>

      <input type="text" name="college" placeholder="Nearby College"
        class="w-full mb-3 p-2 border rounded" required>

      <input type="number" name="price" placeholder="Price"
        class="w-full mb-3 p-2 border rounded" required>

      <input type="text" name="contact" placeholder="Contact"
        class="w-full mb-3 p-2 border rounded" required>

      <input type="file" name="images" multiple
        class="w-full mb-3">

      <!-- 📍 MAP -->
      <label class="font-semibold">Select Location:</label>
      <div id="map" class="mb-3"></div>

      <!-- Hidden lat/lng -->
      <input type="hidden" name="lat" id="lat">
      <input type="hidden" name="lng" id="lng">

      <button class="bg-blue-600 text-white px-4 py-2 rounded w-full">
        Add Room
      </button>

    </form>
  </div>

  <!-- Leaflet JS -->
  <script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>

  <script>
    // Default location (Guwahati)
    const map = L.map('map').setView([26.1445, 91.7362], 13);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png')
      .addTo(map);

    let marker;

    map.on('click', function(e) {
      const { lat, lng } = e.latlng;

      // Remove old marker
      if (marker) map.removeLayer(marker);

      // Add new marker
      marker = L.marker([lat, lng]).addTo(map);

      // Set values
      document.getElementById("lat").value = lat;
      document.getElementById("lng").value = lng;
    });
  </script>

</body>
</html>