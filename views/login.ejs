<!DOCTYPE html>
<html>
<head>
  <title>Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center h-screen">

<form action="/auth/login" method="POST" class="bg-white p-6 rounded shadow w-80">

  <h2 class="text-xl font-bold mb-4">Login</h2>

  <input name="email" type="email" placeholder="Email" class="w-full mb-2 p-2 border" required />
  <input name="password" type="password" placeholder="Password" class="w-full mb-4 p-2 border" required />

  <button class="bg-green-500 text-white w-full py-2 rounded">
    Login
  </button>

</form>

</body>
</html>