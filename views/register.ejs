<!DOCTYPE html>
<html>
<head>
  <title>Register</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center h-screen">

<form action="/auth/register" method="POST" class="bg-white p-6 rounded shadow w-80">

  <h2 class="text-xl font-bold mb-4">Register</h2>

  <input name="name" placeholder="Name" class="w-full mb-2 p-2 border" required />
  <input name="email" type="email" placeholder="Email" class="w-full mb-2 p-2 border" required />
  <input name="password" type="password" placeholder="Password" class="w-full mb-2 p-2 border" required />

  <select name="role" class="w-full mb-4 p-2 border">
    <option value="tenant">Tenant</option>
    <option value="landlord">Landlord</option>
  </select>

  <button class="bg-blue-500 text-white w-full py-2 rounded">
    Register
  </button>

</form>

</body>
</html>