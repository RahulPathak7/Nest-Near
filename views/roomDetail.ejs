<!DOCTYPE html>
<html>
<head>
  <title>Room Details</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

<%- include("partials/navbar") %>

<div class="max-w-5xl mx-auto p-6">

  <% if (!room) { %>
    <h1 class="text-2xl font-bold text-center">Room not found</h1>
  <% } else { %>

    <!-- Title -->
    <h1 class="text-3xl font-bold mb-4"><%= room.title %></h1>

    <!-- Image Gallery -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
      <% if (room.images && room.images.length > 0) { %>
        <% room.images.forEach(img => { %>
          <img src="<%= img %>" class="rounded-lg shadow-md w-full h-64 object-cover">
        <% }) %>
      <% } else { %>
        <img src="/default.jpg" class="rounded-lg shadow-md w-full h-64 object-cover">
      <% } %>
    </div>

    <!-- Details Card -->
    <div class="bg-white p-6 rounded-xl shadow-md">

      <p class="text-gray-700 mb-2">
        <strong>📍 Address:</strong> <%= room.address %>
      </p>

      <!-- ✅ NEW FIELD ADDED -->
      <p class="text-gray-700 mb-2">
        <strong>🎓 Nearby College:</strong> 
        <%= room.college ? room.college : "Not specified" %>
      </p>

      <p class="text-gray-700 mb-2">
        <strong>💰 Price:</strong> ₹<%= room.price %>
      </p>

      <p class="text-gray-700 mb-2">
        <strong>📞 Contact:</strong> <%= room.contact %>
      </p>

      <!-- Save Button -->
      <% if (user) { %>
        <a href="/rooms/save/<%= room._id %>" 
           class="inline-block mt-4 bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
           ❤️ Save Listing
        </a>
      <% } else { %>
        <a href="/auth/login" 
           class="inline-block mt-4 bg-gray-500 text-white px-4 py-2 rounded">
           Login to Save
        </a>
      <% } %>

    </div>

    <!-- Back Button -->
    <div class="mt-6">
      <a href="/rooms" class="text-blue-500 hover:underline">← Back to Rooms</a>
    </div>

  <% } %>

</div>

</body>
</html>