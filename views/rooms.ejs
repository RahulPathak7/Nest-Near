<!DOCTYPE html>
<html>
<head>
  <title>Rooms</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

<%- include("partials/navbar") %>

<div class="p-6">

  <!-- 🔍 SEARCH -->
  <form action="/rooms/search" method="GET" class="mb-6 flex gap-4">
  <input 
    type="text" 
    name="q" 
    placeholder="Search by title, college, or address..."
    class="p-2 border rounded w-1/2"
  >

  <button class="bg-blue-500 text-white px-4 py-2 rounded">
    Search
  </button>
</form>

  <!-- 🏠 ROOMS GRID -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    <% rooms.forEach(room => { %>
      <div class="bg-white rounded-xl shadow hover:shadow-lg transition p-4">

        <% if (room.images && room.images.length > 0) { %>
          <img src="<%= room.images[0] %>" class="w-full h-48 object-cover rounded">
        <% } %>

        <h2 class="text-xl font-bold mt-2"><%= room.title %></h2>
        <p class="text-gray-600">₹<%= room.price %></p>
        <p class="text-sm text-gray-500"><%= room.address %></p>

        <div class="mt-3 flex justify-between items-center">
          <a href="/rooms/<%= room._id %>" class="text-blue-500">View</a>

          <a href="/rooms/save/<%= room._id %>"
             class="bg-red-500 text-white px-3 py-1 rounded">
            ❤️ Save
          </a>
        </div>
      </div>
    <% }) %>

  </div>
</div>

</body>
</html>