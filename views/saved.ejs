<!DOCTYPE html>
<html>
<head>
  <title>Saved Rooms</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

<%- include("partials/navbar") %>

<div class="p-6">
  <h1 class="text-2xl font-bold mb-6">❤️ Saved Homes</h1>

  <% if (rooms.length === 0) { %>
    <div class="text-center text-gray-500 mt-10">
      <p class="text-lg">No saved homes yet 😕</p>
      <a href="/rooms" class="text-blue-500 underline">Browse rooms</a>
    </div>
  <% } %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    <% rooms.forEach(room => { %>
      <div class="bg-white rounded-xl shadow p-4 hover:shadow-lg transition">

        <% if (room.images && room.images.length > 0) { %>
          <img src="<%= room.images[0] %>" class="w-full h-48 object-cover rounded">
        <% } %>

        <h2 class="text-lg font-bold mt-2"><%= room.title %></h2>
        <p class="text-gray-600">₹<%= room.price %></p>
        <p class="text-sm text-gray-500"><%= room.address %></p>

        <div class="mt-4 flex justify-between items-center">

          <a href="/rooms/<%= room._id %>" class="text-blue-500">
            View
          </a>

          <!-- ❌ REMOVE BUTTON -->
          <a href="/rooms/save/<%= room._id %>"
             class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600">
            Remove
          </a>

        </div>
      </div>
    <% }) %>

  </div>
</div>

</body>
</html>